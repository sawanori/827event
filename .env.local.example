# ── 予約システム環境変数 ─────────────────────────────────────────────
# .env.local にコピーして値を設定する（.env.local はコミットしない）。
# 本番は Vercel の Project → Settings → Environment Variables にも同じ値を設定。

# Turso（libSQL）データベース接続
# Turso でDB作成後に発行される接続情報。
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# SendGrid（既存プロジェクトと同じ API キーを流用可）
SENDGRID_API_KEY=your_sendgrid_api_key
# 送信元（SendGrid で認証済みの送信者）。未指定なら info@non-turn.com。
SENDGRID_FROM_EMAIL=info@non-turn.com
SENDGRID_FROM_NAME=NonTurn.LLC

# 管理者通知メールの宛先
ADMIN_NOTIFY_EMAIL=info@non-turn.com

# /admin ログイン用の共有パスワード
ADMIN_PASSWORD=change_me
